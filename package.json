{
  "name": "@liebstoeckel/buncus-workspace",
  "private": true,
  "description": "buncus monorepo: a single-binary, self-hosted host for GitHub Discussions comments (a Bun-native giscus reimplementation).",
  "homepage": "https://github.com/liebstoeckel/buncus#readme",
  "bugs": {
    "url": "https://github.com/liebstoeckel/buncus/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liebstoeckel/buncus.git"
  },
  "license": "MIT",
  "author": {
    "name": "Leon Kaucher",
    "email": "contact@liebstoeckel.app"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "mock": "bun run packages/mock-github/src/cli.ts",
    "test": "bun test packages",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@happy-dom/global-registrator": "^20.10.3",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "playwright": "1.60.0",
    "typescript": "^6.0.3"
  }
}
