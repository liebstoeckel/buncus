    "check:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@happy-dom/global-registrator": "^20.10.3",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "playwright": "1.60.0",
    "typescript": "^6.0.3"
  }
}
