# Copy to .env.demo.local (gitignored) and fill in, then run: bun run demo:live
#
# Runs the buncus binary against REAL GitHub. Prerequisites:
#  - A GitHub App with Discussions: Read and write permission.
#  - The App installed on DEMO_REPO.
#  - The App's OAuth callback URL set to http://localhost:4600/api/oauth/authorized
#    (matches DEMO_BUNCUS_PORT below; change both together).

# --- required ---
GITHUB_CLIENT_ID=Iv23xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Path to the App's downloaded private key (.pem). Alternatively set
# GITHUB_PRIVATE_KEY directly to the PEM contents (\n-escaped).
GITHUB_PRIVATE_KEY_PATH=/abs/path/to/app.private-key.pem

# --- optional ---
# The numeric App ID. Omit it: GitHub accepts the client ID as the JWT issuer.
# GITHUB_APP_ID=123456
# Pin a session key; otherwise a random one is generated per run.
# ENCRYPTION_PASSWORD=

# What to embed (defaults shown).
DEMO_REPO=liebstoeckel/buncus
# DEMO_CATEGORY=General
# DEMO_MAPPING=specific
# DEMO_TERM=buncus-localhost-demo
# DEMO_CONSENT=skip
# DEMO_HOST=localhost
# DEMO_BUNCUS_PORT=4600
# DEMO_PAGE_PORT=4601
