{
  "name": "@liebstoeckel/buncus-server",
  "version": "0.1.3",
  "private": true,
  "description": "A single-binary, themeable, self-hosted host for GitHub Discussions comments. A Bun-native giscus reimplementation.",
  "keywords": [
    "github-discussions",
    "comments",
    "comment-system",
    "comment-widget",
    "giscus",
    "bun",
    "self-hosted",
    "github-app"
  ],
  "homepage": "https://github.com/liebstoeckel/buncus/tree/main/packages/buncus#readme",
  "bugs": {
    "url": "https://github.com/liebstoeckel/buncus/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liebstoeckel/buncus.git",
    "directory": "packages/buncus"
  },
  "license": "MIT",
  "author": {
    "name": "Leon Kaucher",
    "email": "contact@liebstoeckel.app"
  },
  "type": "module",
  "bin": {
    "buncus": "./src/server.ts"
  },
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "build:assets": "bun run scripts/build-assets.ts",
    "build:i18n": "bun run scripts/build-i18n.ts",
    "compile": "bun run build:assets && bun build --compile --outfile dist/buncus src/server.ts",
    "start": "bun run src/server.ts",
    "demo": "bun run scripts/demo.ts",
    "demo:live": "bun run compile && bun run scripts/demo-live.ts",
    "test": "bun test",
    "test:e2e": "bun test test/e2e"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@liebstoeckel/buncus-mock-github": "workspace:*"
  }
}
